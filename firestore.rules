rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profile — only the user can read/write their own record
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Organization data — only members of the org can read/write
    match /organizations/{orgId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid in resource.data.members;
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;

      // Acquisitions
      match /acquisitions/{acquisitionId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)).data.members;
      }

      // Activities
      match /activities/{activityId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)).data.members;
      }

      // Settings (stateOffices, appSettings)
      match /settings/{settingId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)).data.members;
      }

      // Invite codes — members can create, anyone authenticated can read (to join)
      match /invites/{inviteId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)).data.members;
        allow update: if request.auth != null;
        allow delete: if request.auth != null &&
          request.auth.uid == get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
