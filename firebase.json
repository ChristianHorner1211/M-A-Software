{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "server.py",
      "carrier_import_template.csv",
      "README.md",
      ".git/**"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/acquisitions-app-standalone.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  }
}
