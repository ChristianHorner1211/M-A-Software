rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Rules for acquisition documents
    match /acquisitions/{acquisitionId}/{allPaths=**} {
      // Allow authenticated users to read and write
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024  // Max 50MB
                   && request.resource.contentType.matches('application/.*|image/.*|text/.*');
    }

    // Rules for carrier imports (Excel files)
    match /carrier-imports/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // Max 10MB
                   && (request.resource.contentType == 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
                       || request.resource.contentType == 'application/vnd.ms-excel'
                       || request.resource.contentType == 'text/csv');
    }

    // Rules for uploaded documents per acquisition
    match /documents/{acquisitionId}/{documentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 100 * 1024 * 1024;  // Max 100MB per document
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
