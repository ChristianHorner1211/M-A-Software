rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Rules for user-scoped acquisition documents (primary upload path)
    match /users/{userId}/acquisitions/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 500 * 1024 * 1024; // Max 500MB per file
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for acquisition documents (legacy path)
    match /acquisitions/{acquisitionId}/{allPaths=**} {
      // Allow authenticated users to read and write
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 500 * 1024 * 1024; // Max 500MB
      allow delete: if request.auth != null;
    }

    // Rules for carrier imports (Excel files)
    match /carrier-imports/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // Max 10MB
                   && (request.resource.contentType == 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
                       || request.resource.contentType == 'application/vnd.ms-excel'
                       || request.resource.contentType == 'text/csv');
    }

    // Rules for uploaded documents per acquisition
    match /documents/{acquisitionId}/{documentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 500 * 1024 * 1024; // Max 500MB per document
      allow delete: if request.auth != null;
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
